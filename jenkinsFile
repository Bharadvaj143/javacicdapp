pipeline {

    agent any
    environment {
        DOCKER_IMAGE = "bharadvajnanepalli/javacicdapp:latest"
        TOMCAT_HOME = "/home/bannu/tomcat/apache-tomcat-10.1.52"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/Bharadvaj143/javacicdapp.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh 'mvn clean install'
            }
        }
        stage('Deploy to Tomcat') {
            steps {
                script {
                    sh "cp target/*.war ${TOMCAT_HOME}/webapps/"
                    sh "sudo systemctl restart tomcat"
                }
            }
        }
    }
    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}