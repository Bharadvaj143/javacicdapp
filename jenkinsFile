pipeline {

    agent any
    environment {
        DOCKER_IMAGE = "bharadvajnanepalli/javacicdapp:latest"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/Bharadvaj143/javacicdapp.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh 'mvn clean install'
            }
        }
        stage('Deploy war to tomacat') {
            steps {
                sh 'cp target/*.war /home/bannu/tomcat/apache-tomcat-10.1.52/webapps/'
                sh 'cd /home/bannu/tomcat/apache-tomcat-10.1.52/bin && ./shutdown.sh'
                sh 'cd /home/bannu/tomcat/apache-tomcat-10.1.52/bin && ./startup.sh'
            }
        }
    }
    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}